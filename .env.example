# --- Database ---
# Local dev: a SQLite file. Production (Turso): "libsql://<db>.turso.io".
DATABASE_URL="file:./dev.db"
# Only needed for Turso (remote). Leave empty for the local file DB.
DATABASE_AUTH_TOKEN=""

# --- Auth ---
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- File uploads ---
# Local dev only. On Vercel, BLOB_READ_WRITE_TOKEN (set automatically when you
# add Vercel Blob) is used instead and this is ignored.
UPLOAD_DIR="./uploads"
# Set automatically by Vercel when a Blob store is connected; leave empty locally.
BLOB_READ_WRITE_TOKEN=""

# --- Zalo notifications / cron ---
ZALO_OA_ACCESS_TOKEN="your-zalo-oa-access-token"
CRON_SECRET="a-long-random-string"
