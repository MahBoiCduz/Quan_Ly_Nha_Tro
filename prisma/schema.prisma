generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// NOTE: SQLite does not support Prisma `enum` types, so the following columns
// are plain `String`. Allowed values (enforced in the app via zod schemas):
//   Unit.type:           "room" | "commercial"
//   Unit.status:         "occupied" | "vacant"
//   Lease.billingCycle:  "monthly" | "quarterly" | "custom"
//   Bill.status:         "unpaid" | "paid" | "overdue"
//   Payment.method:      "cash" | "bank_transfer"
//   User.role:           "admin"

model Unit {
  id           String        @id @default(cuid())
  name         String
  floor        Int
  type         String
  baseRent     Int
  status       String        @default("vacant")
  serviceItems ServiceItem[]
  leases       Lease[]
  maintenance  MaintenanceSchedule[]
  // Which billing profile (bank account / QR) this room's invoices use.
  // null = the default profile stored on Setting.
  billingProfile   BillingProfile? @relation(fields: [billingProfileId], references: [id])
  billingProfileId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([billingProfileId])
}

// A named set of payment details (owner bank account + QR) so invoices for
// different rooms can show different recipients. The "default" profile lives on
// Setting; these are the extra ones (e.g. another co-owner's account).
model BillingProfile {
  id              String   @id @default(cuid())
  name            String
  bankAccountName String?
  bankAccountNo   String?
  bankName        String?
  qrImageUrl      String?
  invoiceNotes    String?
  // Exactly one row has isDefault = true: the fallback profile used by invoices
  // when neither the bill nor the room specifies one. Enforced in the app layer
  // (SQLite/Prisma can't express a partial unique index without schema drift).
  isDefault       Boolean  @default(false)
  units           Unit[]
  bills           Bill[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ServiceItem {
  id           String  @id @default(cuid())
  unit         Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId       String
  name         String
  measureUnit  String
  defaultPrice Int

  @@index([unitId])
}

model Tenant {
  id                  String   @id @default(cuid())
  fullName            String
  phone               String
  idCardNumber        String?
  idCardFrontImageUrl String?
  idCardBackImageUrl  String?
  vehiclePlate        String?
  zaloId              String?
  notes               String?
  // As the lease's representative (the billing/contact tenant).
  leases              Lease[]  @relation("PrimaryTenant")
  // As an additional occupant sharing a lease (own info + ID card, not billed).
  coLease             Lease?   @relation("CoTenants", fields: [coLeaseId], references: [id])
  coLeaseId           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([coLeaseId])
}

model Lease {
  id                String       @id @default(cuid())
  unit              Unit         @relation(fields: [unitId], references: [id])
  unitId            String
  tenant            Tenant       @relation("PrimaryTenant", fields: [tenantId], references: [id])
  tenantId          String
  coTenants         Tenant[]     @relation("CoTenants")
  startDate         DateTime
  endDate           DateTime?
  agreedRent        Int
  billingCycle      String       @default("monthly")
  depositAmount     Int          @default(0)
  depositCollectedAt DateTime?
  depositCollectedBy String?
  bills             Bill[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([unitId])
  @@index([tenantId])
}

model Bill {
  id                String     @id @default(cuid())
  lease             Lease      @relation(fields: [leaseId], references: [id])
  leaseId           String
  periodLabel       String
  dueDate           DateTime
  status            String     @default("unpaid")
  lineItems         Json
  electricityAmount Int        @default(0)
  waterAmount       Int        @default(0)
  // Meter readings the amounts were derived from (nullable: legacy/manual bills
  // may store only the amount). Electricity is whole kWh, water is m³ (decimals).
  electricityOld    Int?
  electricityNew    Int?
  electricityRate   Int?
  waterOld          Float?
  waterNew          Float?
  waterRate         Int?
  subtotal          Int        @default(0)
  grandTotal        Int        @default(0)
  // Billing profile chosen when the bill was created (null = default on Setting).
  billingProfile    BillingProfile? @relation(fields: [billingProfileId], references: [id])
  billingProfileId  String?
  payments          Payment[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([leaseId])
  @@index([billingProfileId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id              String        @id @default(cuid())
  bill            Bill          @relation(fields: [billId], references: [id])
  billId          String
  amount          Int
  paidAt          DateTime
  method          String
  confirmedBy     String?
  notes           String?
  // Receipt/transfer screenshots for this payment: a JSON array of image URLs.
  // A tenant may send several photos for one transfer (was a single
  // receiptImageUrl before migration 20260704000000).
  receiptImages   Json          @default("[]")
  createdAt       DateTime      @default(now())

  @@index([billId])
  @@index([paidAt])
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  category    String
  amount      Int
  createdAt   DateTime @default(now())

  @@index([date])
}

model MaintenanceSchedule {
  id           String            @id @default(cuid())
  name         String
  scope        String
  unit         Unit?             @relation(fields: [unitId], references: [id])
  unitId       String?
  intervalDays Int
  lastDoneAt   DateTime?
  nextDueAt    DateTime
  notes        String?
  logs         MaintenanceLog[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([unitId])
  @@index([nextDueAt])
}

model MaintenanceLog {
  id         String              @id @default(cuid())
  schedule   MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId String
  doneAt     DateTime
  notes      String?

  @@index([scheduleId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

// Operational config singleton. The default *payment* profile (bank account /
// QR / notes) used to live here but was consolidated into a
// BillingProfile{isDefault} row (see migration 20260702000000).
model Setting {
  id                     String  @id @default("singleton")
  adminZaloUserId        String?
  defaultElectricityRate Int?
  defaultWaterRate       Int?
}

model NotificationLog {
  key    String   @id
  sentAt DateTime @default(now())
}
